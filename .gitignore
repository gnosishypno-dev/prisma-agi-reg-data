# PRISMA Study 2 — .gitignore
# SECURITY: Never commit prompt files or API credentials

# Prompt files
condition_a_prompt*.txt
condition_a_prompt*.md
*_prompt_HIGH.txt
*_prompt_LOW.txt
*_prompt_DOWN.txt

# Configuration files (contain API keys)
prisma_claude_config_v2.py
spectra_config.py
*_config_v*.py
*.env
.env
.env.*

# API keys and credentials
*api_key*
*apikey*
*secret*
*credentials*

# Python artifacts
__pycache__/
*.py[cod]

# OS artifacts
.DS_Store
._*

# Editor artifacts
.vscode/
.idea/
*.swp
*~
